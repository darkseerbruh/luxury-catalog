# ---- Supabase (existing) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- PostHog (browser, public) ----
# Project API Key from PostHog -> Settings -> Project. Safe to expose.
NEXT_PUBLIC_POSTHOG_KEY=
# Only set if NOT using US cloud (e.g. https://eu.posthog.com for the toolbar).
NEXT_PUBLIC_POSTHOG_UI_HOST=

# ---- PostHog (server, optional) ----
# Used by src/lib/analytics/server.ts. Falls back to the public key if unset.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ---- Weekly analytics digest (scripts/analytics-digest.ts) ----
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
ANTHROPIC_API_KEY=
# Optional: override the report-generation model.
ANALYTICS_DIGEST_MODEL=
# Optional: enriches the digest with product-gap data.
SUPABASE_SERVICE_ROLE_KEY=
