# ---- Supabase (existing) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only service-role key (admin dashboards, seeds, price-alert cron).
# (Also listed under the analytics digest below.)

# ---- Affiliate "where to buy" links (all optional) ----
# Per-platform affiliate/partner codes; omit for plain (non-monetized) links.
NEXT_PUBLIC_AFFILIATE_FASHIONPHILE=
NEXT_PUBLIC_AFFILIATE_THEREALREAL=
NEXT_PUBLIC_AFFILIATE_VESTIAIRE=
# Optional affiliate-network wrapper; "{url}" is replaced with the encoded target.
# Skimlinks deep-link format: https://go.skimresources.com/?id=<PUBLISHER_ID>&xs=1&url={url}
NEXT_PUBLIC_AFFILIATE_WRAP_TEMPLATE=
# Skimlinks site script publisher id (defaults to our account in code if unset).
NEXT_PUBLIC_SKIMLINKS_ID=

# ---- eBay Browse API (current resale prices via npm run ingest:ebay) ----
# Production keyset from developer.ebay.com → My Account → Application Keys.
EBAY_APP_ID=
EBAY_CERT_ID=

# ---- Price-alert cron + email (price-alert delivery) ----
# Shared secret Vercel Cron sends as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=
# Optional: Resend API key to email alerts. Without it, alerts are in-app only.
RESEND_API_KEY=
# From-address for alert emails (must be a verified Resend sender/domain).
ALERTS_FROM_EMAIL=alerts@luxurycatalog.com

# ---- Instagram embeds (Meta oEmbed Read API) ----
# Server-only. Required to render Instagram posts in the bag-page "Reviews &
# social" section (src/lib/instagram.ts). Without it, Instagram resources
# gracefully degrade to an attribution link-out. The unauthenticated oEmbed
# endpoint was removed in April 2025 — you need a registered Meta app with the
# "oEmbed Read" feature approved + business verification. See
# docs/social-embed-strategy.md. Provide EITHER a ready token:
META_OEMBED_TOKEN=
# OR the app id + secret (the server composes "<id>|<secret>" as the app token):
META_APP_ID=
META_APP_SECRET=

# ---- PostHog (browser, public) ----
# Project API Key from PostHog -> Settings -> Project. Safe to expose.
NEXT_PUBLIC_POSTHOG_KEY=
# Only set if NOT using US cloud (e.g. https://eu.posthog.com for the toolbar).
NEXT_PUBLIC_POSTHOG_UI_HOST=

# ---- PostHog (server, optional) ----
# Used by src/lib/analytics/server.ts. Falls back to the public key if unset.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ---- Weekly analytics digest (scripts/analytics-digest.ts) ----
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
ANTHROPIC_API_KEY=
# Optional: override the report-generation model.
ANALYTICS_DIGEST_MODEL=
# Optional: enriches the digest with product-gap data.
SUPABASE_SERVICE_ROLE_KEY=
